{
    "$schema": "https://json.schemastore.org/prettierrc",
    "semi": false,
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 4,
    "importOrder": [
        "^@/core/(.*)$",
        "^@/pages/(.*)$",
        "^@/common/(.*)$",
        "^@/modules/.*/components/(.*)$",
        "^@/modules/.*/composables/(.*)$",
        "^@/modules/.*/modals/(.*)$",
        "^@/modules/.*/models/(.*)$",
        "^@/modules/.*/consts/(.*)$",
        "^@/modules/.*/helpers/(.*)$",
        "^@/modules/.*/services/(.*)$",
        "^../(.*)$",
        "^./(.*)$",
        "<THIRD_PARTY_MODULES>"
    ],
    "importOrderSeparation": true,
    "importOrderSortSpecifiers": true,
    "plugins": ["prettier-plugin-tailwindcss", "@trivago/prettier-plugin-sort-imports"]
}
